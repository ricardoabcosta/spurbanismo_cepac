# =============================================================================
# CEPAC — Variáveis de ambiente (template)
# Copie para .env e preencha os valores. Não commitar o .env.
# =============================================================================

# ---------------------------------------------------------------------------
# Banco de dados
# ---------------------------------------------------------------------------
# Local (docker compose):
DATABASE_URL=postgresql+asyncpg://cepac:cepac@localhost:5432/cepac
# Produção:
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/cepac?ssl=require

# ---------------------------------------------------------------------------
# Azure AD — obtidos após criação do App Registration
# ---------------------------------------------------------------------------
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=

# ---------------------------------------------------------------------------
# Azure Blob Storage — obtidos após deploy do Bicep
# ---------------------------------------------------------------------------
AZURE_BLOB_ACCOUNT_NAME=cepacstorageacct
AZURE_BLOB_ACCOUNT_KEY=
AZURE_BLOB_CONTAINER_NAME=cepac-documentos

# ---------------------------------------------------------------------------
# CORS — em produção: URLs dos Container Apps separadas por vírgula
# ---------------------------------------------------------------------------
CORS_ORIGINS=*
