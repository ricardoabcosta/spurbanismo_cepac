# =============================================================================
# CEPAC — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Segredos e configuração local — NUNCA commitar
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
azure.txt
*.env

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
ENV/
pip-wheel-metadata/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
*.log

# ---------------------------------------------------------------------------
# Node / React / Vite
# ---------------------------------------------------------------------------
node_modules/
dist/
.vite/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Claude Code (configurações locais do agente)
# ---------------------------------------------------------------------------
.claude/

# ---------------------------------------------------------------------------
# IDE e SO
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
*.dockerignore.local

# ---------------------------------------------------------------------------
# Azure / Terraform / Bicep artefatos
# ---------------------------------------------------------------------------
infra/bicep/*.json.bak
.azure/

# ---------------------------------------------------------------------------
# Uploads e artefatos gerados
# ---------------------------------------------------------------------------
uploads/
*.xlsx.bak
.aider*
