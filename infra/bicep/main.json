              "server": "[variables('acrLoginServer')]",
              "identity": "system"
            }
          ],
          "secrets": [
            {
              "name": "database-url",
              "value": "[format('postgresql+asyncpg://{0}:{1}@{2}:5432/cepac?ssl=require', parameters('dbAdminLogin'), parameters('dbAdminPassword'), reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgServerName')), '2023-06-01-preview').fullyQualifiedDomainName)]"
            },
            {
              "name": "blob-account-key",
              "value": "[listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-04-01').keys[0].value]"
