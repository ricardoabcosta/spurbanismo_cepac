        "description": "Tag de imagem do container (ex: sha-abc123)"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Region para todos os recursos"
      }
    }
  },
  "variables": {
