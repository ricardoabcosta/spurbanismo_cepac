                  "name": "AZURE_BLOB_CONTAINER_NAME",
                  "value": "[variables('blobContainerName')]"
                },
                {
                  "name": "CORS_ORIGINS",
                  "value": "*"
                }
              ],
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/health",
                    "port": 8000
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 30,
                  "failureThreshold": 3
                },
                {
                  "type": "Readiness",
